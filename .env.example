# Pipeline Controller Environment Variables
# Copy to .env or set via systemd override

# Linear API (personal key — fallback for reading, OAuth token preferred)
LINEAR_API_KEY=lin_api_...

# Linear OAuth App (for posting as "TwiceD Pipeline" bot)
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_OAUTH_TOKEN=lin_oauth_...
LINEAR_REFRESH_TOKEN=lin_refresh_...

# Linear Webhook (signing secret from OAuth app config)
LINEAR_WEBHOOK_SECRET=lin_wh_...

# GitHub PAT (Contents, Issues, Metadata, Pull requests — read+write)
GITHUB_TOKEN=github_pat_...

# Database path (SQLite)
DATABASE_PATH=./pipeline.db

# Server port
PORT=3200

# SSH user for gateway VMs
SSH_USER=admin

# VM directory layout (paths on gateway VMs)
WORKSPACE_BASE_DIR=~/workspaces
REPO_BASE_DIR=~/repos
WORKTREE_BASE_DIR=~/worktrees

# Default ports for new gateways
DEFAULT_GATEWAY_PORT=18789
DEFAULT_TTYD_PORT=7681

# Timeouts
AGENT_TASK_TIMEOUT_MINUTES=30
FULL_RUN_TIMEOUT_MINUTES=120
CLEANUP_RETENTION_DAYS=7
PERIODIC_INTERVAL_MS=300000
SSE_HEARTBEAT_MS=15000
